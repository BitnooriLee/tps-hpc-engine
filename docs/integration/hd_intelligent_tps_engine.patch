+def find_best_window(sqrt_t, delta_t, min_fraction=0.30, use_omp=False):
+    """
+    C++ replacement path (pybind11).
+    Output contract intentionally matches legacy NumPy caller expectations.
+    """
+    fn = tps_engine.find_best_window_omp if use_omp else tps_engine.find_best_window_serial
+    res = fn(sqrt_t, delta_t, min_fraction=min_fraction)
+    return {
+        "start": res["start"],
+        "end": res["end"],
+        "verdict": res["verdict"],
+        "rmse": res["rmse"],
+        "runs_ok": res["runs_ok"],
+        "dw_ok": res["dw_ok"],
+        "hetero_ok": res["hetero_ok"],
+        "trend_ok": res["trend_ok"],
+        "issues": list(res["issues"]),
+        "selection_note": res.get("selection_note", ""),
+    }

