+def _prefer_cpp_backend() -> bool:
+    """
+    Select residual backend via env var:
+      TPS_RESIDUAL_BACKEND=auto|cpp|numpy
+    """
+    backend = os.getenv("TPS_RESIDUAL_BACKEND", "auto").strip().lower()
